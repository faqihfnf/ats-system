generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Divisi {
  id        String     @id @default(cuid())
  nama      String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  positions Position[]

  @@map("divisi")
}

model Level {
  id        String     @id @default(cuid())
  nama      String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  positions Position[]

  @@map("level")
}

model Position {
  id        String   @id @default(cuid())
  nama      String
  divisiId  String
  divisi    Divisi   @relation(fields: [divisiId], references: [id])
  levelId   String
  level     Level    @relation(fields: [levelId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  jobs      Job[]

  @@map("positions")
}

model Profile {
  id        String   @id
  nama      String
  email     String   @unique
  role      Role     @default(RECRUITER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  jobs      Job[]

  @@map("profiles")
}

enum Role {
  ADMIN
  RECRUITER
}

model Stage {
  id           String        @id @default(cuid())
  name         String        @unique
  order        Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  applications Application[]

  @@map("stages")
}

model Branch {
  id        String   @id @default(cuid())
  name      String   @unique
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  jobs      Job[]

  @@map("branches")
}

model EmploymentStatus {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  jobs      Job[]

  @@map("employment_statuses")
}

model Education {
  id           String        @id @default(cuid())
  name         String        @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  jobs         Job[]
  applications Application[]

  @@map("educations")
}

model Experience {
  id        String   @id @default(cuid())
  name      String   @unique
  minYears  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  jobs      Job[]

  @@map("experiences")
}

model Job {
  id                 String           @id @default(cuid())
  // Informasi Umum (step 1)
  positionId         String
  position           Position         @relation(fields: [positionId], references: [id])
  branchId           String
  branch             Branch           @relation(fields: [branchId], references: [id])
  employmentStatusId String
  employmentStatus   EmploymentStatus @relation(fields: [employmentStatusId], references: [id])
  province           String
  city               String
  minSalary          Int
  maxSalary          Int
  showSalary         Boolean          @default(false)

  // Informasi Pekerjaan (step 2)
  description  String? @db.Text
  requirements String? @db.Text

  // Kualifikasi (step 3)
  minEducationId  String
  minEducation    Education  @relation(fields: [minEducationId], references: [id])
  minExperienceId String
  minExperience   Experience @relation(fields: [minExperienceId], references: [id])
  minAge          Int
  maxAge          Int
  showAge         Boolean    @default(false)
  gender          Gender     @default(ANY)
  showGender      Boolean    @default(false)
  religion        Religion   @default(ANY)
  showReligion    Boolean    @default(false)

  // Custom Question (step 4)
  customQuestions CustomQuestion[]

  applications Application[]

  status    JobStatus @default(DRAFT)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String
  creator   Profile   @relation(fields: [createdBy], references: [id])

  @@map("jobs")
}

enum Gender {
  MALE
  FEMALE
  ANY
}

enum Religion {
  ISLAM
  KRISTEN
  KATOLIK
  HINDU
  BUDDHA
  KONGHUCU
  ANY
}

enum JobStatus {
  DRAFT
  OPEN
  CLOSED
}

model CustomQuestion {
  id    String @id @default(cuid())
  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  question String
  type     QuestionType
  required Boolean      @default(false)
  order    Int

  options String? // JSON string untuk MULTIPLE_CHOICE, CHECKBOX, DROPDOWN

  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  applicationAnswers ApplicationAnswer[]

  @@map("custom_questions")
}

enum QuestionType {
  SHORT_TEXT
  LONG_TEXT
  NUMBER
  DATE
  MULTIPLE_CHOICE
  CHECKBOX
  DROPDOWN
  YES_NO
}

model Application {
  id    String @id @default(cuid())
  jobId String
  job   Job    @relation(fields: [jobId], references: [id])

  // Data Personal
  fullName        String
  email           String
  phone           String
  birthPlace      String
  birthDate       DateTime
  religion        Religion
  gender          Gender   @default(MALE)
  ktpAddress      String   @db.Text
  domicileAddress String   @db.Text
  sameAsKtp       Boolean  @default(false)
  province        String
  city            String
  district        String
  subdistrict     String

  // Pendidikan Terakhir
  educationId String
  education   Education @relation(fields: [educationId], references: [id])
  institution String
  startYear   Int
  endYear     String

  // Pengalaman Kerja Terakhir 
  lastJobTitle String?
  lastCompany  String?
  jobStartYear Int?
  jobEndYear   String? // "present" jika masih bekerja
  stillWorking Boolean @default(false)

  // Gaji
  currentSalary  Int?
  expectedSalary Int

  // Upload CV
  cvUrl String?

  // Custom Question Answers
  answers ApplicationAnswer[]

  // Status tracking
  currentStageId String?
  currentStage   Stage?          @relation(fields: [currentStageId], references: [id])
  status         ApplicantStatus @default(ACTIVE)

  // AI Scoring
  totalScore      Int?      @default(0)
  educationScore  Int?      @default(0)
  experienceScore Int?      @default(0)
  ageScore        Int?      @default(0)
  salaryScore     Int?      @default(0)
  genderScore     Int?      @default(0)
  religionScore   Int?      @default(0)
  scoredAt        DateTime?

  // AI Analysis (NEW)
  aiStrengths       String?   @db.Text // Kelebihan
  aiWeaknesses      String?   @db.Text // Kekurangan
  aiConclusion      String?   @db.Text // Kesimpulan
  aiRecommendation  String? // RECOMMENDED | SUGGESTED | NOT_RECOMMENDED
  aiMatchPercentage Int? // 0-100
  analyzedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("applications")
}

enum ApplicantStatus {
  ACTIVE
  HIRED
  REJECTED
  WITHDRAWN
}

model ApplicationAnswer {
  id            String         @id @default(cuid())
  applicationId String
  application   Application    @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  questionId    String
  question      CustomQuestion @relation(fields: [questionId], references: [id])

  answer    String   @db.Text
  createdAt DateTime @default(now())

  @@map("application_answers")
}
